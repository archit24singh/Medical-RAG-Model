      "id": "file:backend/rag/intent_parser.py",
      "type": "file",
      "name": "intent_parser.py",
      "filePath": "backend/rag/intent_parser.py",
      "summary": "Parses plain-English clinical queries into structured intent dictionaries using regex-based pattern matching, extracting entities such as patient names, provider names, dates, ICD-10 codes, and document types for downstream retrieval filtering.",
      "tags": ["utility", "validation", "service", "query-parsing", "nlp"],
      "complexity": "complex"
    },
    {
