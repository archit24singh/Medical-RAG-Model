      "complexity": "moderate"
    },
    {
      "id": "function:backend/rag/intent_parser.py:_regex_parse",
      "type": "function",
      "name": "_regex_parse",
      "filePath": "backend/rag/intent_parser.py",
      "lineRange": [171, 317],
      "summary": "Core regex parsing engine that extracts structured entities from a clinical query, identifying document types, date ranges, NPI numbers, patient/admission IDs, diagnostic codes, structured fields, and patient/provider names through layered pattern matching.",
      "tags": ["utility", "query-parsing", "nlp", "regex"],
      "complexity": "complex"
    },
    {
