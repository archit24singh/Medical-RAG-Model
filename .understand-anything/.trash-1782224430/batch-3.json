      "summary": "Normalizes extracted intent fields by title-casing names and validating ICD-10 code format, ensuring consistent entity representation before retrieval.",
      "tags": ["utility", "validation", "normalization"],
      "complexity": "moderate"
    },
    {
      "id": "function:backend/rag/intent_parser.py:build_where_filter",
      "type": "function",
      "name": "build_where_filter",
      "filePath": "backend/rag/intent_parser.py",
      "lineRange": [121, 166],
