    },
    {
      "id": "function:backend/rag/query_router.py:route",
      "type": "function",
      "name": "route",
      "filePath": "backend/rag/query_router.py",
      "lineRange": [47, 94],
      "summary": "Classifies a parsed intent into a retrieval strategy (analytical aggregate, SQL patient lookup, ICD-10 structured lookup, or vector RAG) by inspecting intent fields and setting routing flags in the returned dictionary.",
      "tags": ["routing", "middleware", "service"],
      "complexity": "moderate"
    },
    {
      "id": "file:backend/rag/retriever.py",
      "type": "file",
      "name": "retriever.py",
      "filePath": "backend/rag/retriever.py",
