      "type": "function",
      "name": "_is_analytical_query",
      "filePath": "backend/rag/intent_parser.py",
      "lineRange": [52, 62],
      "summary": "Detects whether a query is an analytical/aggregation request (e.g., counts, totals, averages) by matching against a compiled regex pattern.",
      "tags": ["utility", "validation", "query-parsing"],
      "complexity": "simple"
    },
    {
      "id": "function:backend/rag/intent_parser.py:parse_intent",
      "type": "function",
