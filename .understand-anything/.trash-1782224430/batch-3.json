      "complexity": "complex"
    },
    {
      "id": "function:backend/rag/retriever.py:_get_reranker",
      "type": "function",
      "name": "_get_reranker",
      "filePath": "backend/rag/retriever.py",
      "lineRange": [56, 66],
      "summary": "Lazily initializes and caches a sentence-transformers CrossEncoder model for relevance reranking, returning None on load failure.",
      "tags": ["service", "utility", "ml-model"],
      "complexity": "simple"
    },
    {
      "id": "function:backend/rag/retriever.py:_rerank",
      "type": "function",
      "name": "_rerank",
      "filePath": "backend/rag/retriever.py",
      "lineRange": [69, 102],
      "summary": "Reranks retrieved documents using a cross-encoder model, scoring query-document pairs and returning the top-k results sorted by relevance score.",
      "tags": ["service", "utility", "ml-model"],
      "complexity": "moderate"
    },
    {
      "id": "function:backend/rag/retriever.py:_filter_by_threshold",
      "type": "function",
      "name": "_filter_by_threshold",
      "filePath": "backend/rag/retriever.py",
      "lineRange": [110, 141],
      "summary": "Filters retrieved documents below a minimum relevance score threshold, falling back to top results if all candidates fail the threshold to prevent empty result sets.",
