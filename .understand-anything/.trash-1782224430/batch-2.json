      "id": "file:backend/db/operations.py",
      "type": "file",
      "name": "operations.py",
      "filePath": "backend/db/operations.py",
      "summary": "Provides all PostgreSQL data-access operations for the medical RAG system: upsert and fuzzy-match resolution for patients, providers, and admissions, plus record insertion and multi-criteria querying against the clinical records table.",
      "tags": ["data-model", "service", "utility", "database"],
      "complexity": "complex"
    },
    {
      "id": "function:backend/db/operations.py:find_or_create_patient",
      "type": "function",
      "name": "find_or_create_patient",
      "filePath": "backend/db/operations.py",
      "lineRange": [80, 145],
      "summary": "Resolves an incoming patient record to an existing database row using exact patient_id, subject_id, or fuzzy name matching, creating a new row only when no match is found and updating demographic fields otherwise.",
      "tags": ["data-model", "database", "utility"],
      "complexity": "complex"
    },
    {
      "id": "function:backend/db/operations.py:find_or_create_provider",
      "type": "function",
      "name": "find_or_create_provider",
      "filePath": "backend/db/operations.py",
      "lineRange": [175, 224],
      "summary": "Resolves a provider by NPI exact match or fuzzy name similarity, inserting a new provider row when no existing match exceeds the confidence threshold.",
      "tags": ["data-model", "database", "utility"],
      "complexity": "moderate"
    },
    {
      "id": "function:backend/db/operations.py:insert_record",
      "type": "function",
