# ── Copy this file to .env and fill in your values ───────────────────────────
# cp .env.example .env

# LLM Provider: "ollama" (free, fully local) or "openai" (requires API key)
LLM_PROVIDER=ollama

# ── Ollama Settings (used when LLM_PROVIDER=ollama) ──────────────────────────
# 1. Install Ollama from https://ollama.com
# 2. Run: ollama pull mistral
# 3. Keep Ollama running in the background while using this app
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=mistral

# ── OpenAI Settings (used when LLM_PROVIDER=openai) ──────────────────────────
# Uncomment and fill in if using OpenAI instead of Ollama
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_MODEL=gpt-4o-mini

# ── Storage ───────────────────────────────────────────────────────────────────
# BUCKET_DIR points to the local bucket/ folder (mounted via docker-compose.yml).
# To upgrade to S3: set BUCKET_DIR to your S3 URI and update ingestion.py loaders.
BUCKET_DIR=/app/bucket

# Automatically ingest all files from bucket/ when the backend starts
AUTO_INGEST=true
